FROM golang:1.25-alpine AS build-stage

WORKDIR /usr/src/app
COPY go.mod go.sum* ./
RUN apk add --no-cache ca-certificates && go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o server .
RUN go test ./...

# Create a non-root user for the final image
RUN echo "appuser:x:10001:10001:appuser:/:" > /etc_passwd

FROM scratch

COPY --from=build-stage /etc_passwd /etc/passwd
COPY --from=build-stage /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=build-stage /usr/src/app/server /server

USER appuser
EXPOSE 8080
ENTRYPOINT ["/server"]
